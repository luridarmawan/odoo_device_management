<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Log List (Tree) View -->
    <record id="view_device_management_log_tree" model="ir.ui.view">
        <field name="name">device.management.log.tree</field>
        <field name="model">device.management.log</field>
        <field name="arch" type="xml">
            <list string="Maintenance Logs">
                <field name="date"/>
                <field name="device_id"/>
                <field name="department_id"/>
                <field name="user_id"/>
                <field name="title"/>
                <field name="log_type" widget="badge" decoration-info="log_type == 'maintenance'" decoration-warning="log_type == 'repair'" decoration-success="log_type == 'upgrade'" decoration-danger="log_type == 'troubleshooting'"/>
            </list>
        </field>
    </record>

    <!-- Log Form View -->
    <record id="view_device_management_log_form" model="ir.ui.view">
        <field name="name">device.management.log.form</field>
        <field name="model">device.management.log</field>
        <field name="arch" type="xml">
            <form string="Log Entry">
                <sheet>
                    <group>
                        <group>
                            <field name="device_id" options="{'no_create': True}"/>
                            <field name="date"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="log_type"/>
                            <field name="title" placeholder="e.g. System upgrade, replaced SSD"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Detailed Description" name="description_page">
                            <field name="description" placeholder="Describe the work done, troubleshooting steps, or spare parts replaced..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Log Search View -->
    <record id="view_device_management_log_search" model="ir.ui.view">
        <field name="name">device.management.log.search</field>
        <field name="model">device.management.log</field>
        <field name="arch" type="xml">
            <search string="Search Logs">
                <field name="title"/>
                <field name="description"/>
                <field name="device_id"/>
                <field name="user_id"/>
                <filter string="Maintenance" name="filter_maintenance" domain="[('log_type', '=', 'maintenance')]"/>
                <filter string="Repair" name="filter_repair" domain="[('log_type', '=', 'repair')]"/>
                <filter string="Upgrade" name="filter_upgrade" domain="[('log_type', '=', 'upgrade')]"/>
                <filter string="Troubleshooting" name="filter_troubleshooting" domain="[('log_type', '=', 'troubleshooting')]"/>
                <filter string="Device" name="group_by_device" context="{'group_by': 'device_id'}"/>
                <filter string="Technician" name="group_by_user" context="{'group_by': 'user_id'}"/>
                <filter string="Log Type" name="group_by_log_type" context="{'group_by': 'log_type'}"/>
                <filter string="Month" name="group_by_date" context="{'group_by': 'date:month'}"/>
            </search>
        </field>
    </record>

    <!-- Log Graph View -->
    <record id="view_device_management_log_graph" model="ir.ui.view">
        <field name="name">device.management.log.graph</field>
        <field name="model">device.management.log</field>
        <field name="arch" type="xml">
            <graph string="Logs Analysis" type="bar">
                <field name="date" interval="month" type="row"/>
                <field name="log_type" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Log Pivot View -->
    <record id="view_device_management_log_pivot" model="ir.ui.view">
        <field name="name">device.management.log.pivot</field>
        <field name="model">device.management.log</field>
        <field name="arch" type="xml">
            <pivot string="Logs Analysis">
                <field name="date" interval="month" type="row"/>
                <field name="log_type" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- Window Action -->
    <record id="action_device_management_log" model="ir.actions.act_window">
        <field name="name">Maintenance Logs</field>
        <field name="res_model">device.management.log</field>
        <field name="view_mode">list,form,graph,pivot</field>
        <field name="search_view_id" ref="view_device_management_log_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No logs recorded yet.
            </p>
            <p>
                Keep track of all maintenance, troubleshooting, and repairs done on devices.
            </p>
        </field>
    </record>
</odoo>
